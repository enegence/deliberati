# Required
OPENROUTER_API_KEY=sk-or-v1-...
# Or mount a file and use:
# OPENROUTER_API_KEY_FILE=/run/secrets/openrouter_api_key

# Optional: Postgres connection (auto-started via Docker if omitted)
DATABASE_URL=postgresql://llm_council:llm_council@127.0.0.1:5432/llm_council
# Or:
# DATABASE_URL_FILE=/run/secrets/database_url

# Optional browser auth hardening
COUNCIL_CSRF_PROTECTION=true
# Set true only when serving behind HTTPS/TLS.
COUNCIL_SECURE_COOKIES=false
